{
  "name": "cap-service",
  "version": "1.0.0",
  "description": "SCM AI CAP Service — works with Node.js and Python agentic stacks",
  "scripts": {
    "start":           "cds-serve",
    "dev":             "cds watch",
    "dev:node":        "AGENT_STACK=node cds watch",
    "dev:python":      "AGENT_STACK=python cds watch",
    "test":            "jest --runInBand",
    "test:unit":       "jest test/unit --runInBand",
    "test:coverage":   "jest --coverage",
    "test:watch":      "jest --watch"
  },
  "dependencies": {
    "@sap/cds":  "^8.5.1",
    "express":   "^4.18.0"
  },
  "devDependencies": {
    "@sap/cds-dk": "^8.5.1",
    "sqlite3":     "^5.1.0",
    "jest":        "^29.0.0"
  },
  "jest": {
    "testEnvironment": "node",
    "testMatch":       ["**/test/**/*.test.js"],
    "collectCoverageFrom": [
      "srv/**/*.js",
      "!srv/**/*.test.js"
    ],
    "coverageReporters": ["text", "lcov"],
    "verbose": true
  },
  "cds": {
    "requires": {
      "db": {
        "kind":        "sqlite",
        "credentials": { "database": ":memory:" }
      }
    }
  }
}